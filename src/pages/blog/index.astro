---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const siloLabels: Record<string, string> = {
  strategy:       'Strategy',
  bonuses:        'Bonuses',
  rtp:            'Math & RTP',
  beginner:       'Beginners',
  'buying-intent': 'Casino Picks',
  predictor:      'Predictor & Stats',
};
---
<BaseLayout
  title="Crazy Time Strategy Blog — All Articles 2026"
  description="All Crazy Time strategy articles, RTP guides, beginner tutorials, bonus round breakdowns, and predictor data analysis."
>
  <div class="max-w-5xl mx-auto px-4 py-10">
    <h1>Crazy Time Strategy Blog</h1>
    <p class="text-slate-400 mb-8">{posts.length} articles covering strategy, odds, bonus rounds, and more.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {posts.map(post => (
        <a
          href={`/blog/${post.id}`}
          class="bg-slate-800 hover:bg-slate-700 border border-slate-700 hover:border-amber-500/30 rounded-xl p-5 transition block"
        >
          <span class="text-xs text-amber-500 font-semibold uppercase tracking-wider">
            {siloLabels[post.data.silo] ?? post.data.silo}
          </span>
          <h2 class="text-base font-semibold text-slate-100 mt-2 mb-1 leading-snug">
            {post.data.title}
          </h2>
          <p class="text-slate-400 text-sm line-clamp-2 m-0">{post.data.description}</p>
          <p class="text-xs text-slate-600 mt-3 m-0">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
