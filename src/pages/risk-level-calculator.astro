---
import BaseLayout from '../layouts/BaseLayout.astro';
import BankrollCalculator from '../components/BankrollCalculator';
import StakeCTA from '../components/StakeCTA.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Crazy Time Risk Level Calculator',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Web',
  description: 'Calculate your Crazy Time risk level and get a personalized strategy recommendation with exact bet sizes.',
  url: 'https://crazytimestrategy.top/risk-level-calculator',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---
<BaseLayout
  title="Crazy Time Risk Level Calculator — Conservative to Aggressive 2026"
  description="Calculate your Crazy Time risk level and get a strategy recommendation. Conservative, balanced, or aggressive — with exact bet sizes."
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1>Crazy Time Risk Level Calculator</h1>
    <p class="text-slate-400 mb-8">
      Enter your bankroll and select a risk level to get a full strategy recommendation.
    </p>

    <BankrollCalculator client:load />

    <div class="mt-10 prose prose-invert max-w-none">
      <h2>Understanding Risk Levels</h2>
      <p>
        Risk level in Crazy Time is about how much of your bankroll you stake per round, not which segments you bet on. A higher risk level means bigger bets, shorter sessions, and larger swings.
      </p>
      <p>
        For a deeper breakdown of each approach, read our <a href="/crazy-time-strategy">Crazy Time strategy guide</a>.
        Learn how bet sizing connects to <a href="/crazy-time-bankroll-strategy">bankroll management</a>.
        Check the <a href="/crazy-time-rtp">RTP breakdown</a> to understand what each segment returns long-term.
        <a href="/where-to-play-crazy-time">Find where to play Crazy Time</a> with these strategies.
      </p>
    </div>

    <StakeCTA variant="card" />
    <StakeCTA variant="sticky" />
  </div>
</BaseLayout>
