---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const {
  title,
  description = 'Crazy Time strategy guides, bankroll tools, RTP data, and the only live RNG pattern tracker.',
  canonical,
  ogImage = '/og-default.svg',
  schema,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CrazyTimeStrategy.top',
  url: Astro.site?.href ?? 'https://crazytimestrategy.top',
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site?.href ?? 'https://crazytimestrategy.top'}blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const activeSchema = schema ?? websiteSchema;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | CrazyTimeStrategy.top</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | CrazyTimeStrategy.top`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="CrazyTimeStrategy.top" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | CrazyTimeStrategy.top`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(activeSchema)} />
</head>
<body class="min-h-screen flex flex-col">
  <Nav />
  <main class="flex-1">
    <slot />
  </main>
  <footer class="border-t border-slate-700 py-8 px-4 text-center text-sm text-slate-500">
    <p class="mb-2">CrazyTimeStrategy.top — Educational content only. Play responsibly. 18+</p>
    <p>
      We earn commission from casino referrals.
      <a href="/affiliate-disclosure" class="underline ml-1">Affiliate Disclosure</a>
      <span class="mx-2">·</span>
      <a href="/crazy-time-strategy" class="underline">Strategy Guide</a>
      <span class="mx-2">·</span>
      <a href="/crazy-time-predictor" class="underline">Live Predictor</a>
    </p>
  </footer>
</body>
</html>
