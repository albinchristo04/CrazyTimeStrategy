---
const links = [
  { href: '/crazy-time-strategy',  label: 'Strategy' },
  { href: '/crazy-time-rtp',       label: 'RTP & Odds' },
  { href: '/crazy-time-guide',     label: 'Beginners' },
  { href: '/crazy-time-predictor', label: '🔴 Live Predictor' },
  { href: '/bankroll-calculator',  label: 'Tools' },
  { href: '/blog',                 label: 'Blog' },
];

const current = Astro.url.pathname;
---
<header class="bg-slate-800 border-b border-slate-700 sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="font-bold text-amber-400 text-base hover:text-amber-300 transition shrink-0">
      CrazyTimeStrategy.top
    </a>
    <nav class="hidden md:flex items-center gap-6">
      {links.map(l => (
        <a
          href={l.href}
          class={`text-sm transition ${
            current === l.href
              ? 'text-amber-400 font-semibold'
              : 'text-slate-300 hover:text-slate-100'
          }`}
        >
          {l.label}
        </a>
      ))}
    </nav>
    <a
      href="https://stake.ac/?c=4GH1nePX"
      target="_blank"
      rel="noopener sponsored"
      class="hidden md:inline-flex bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-sm px-4 py-1.5 rounded-lg transition"
    >
      Play on Stake →
    </a>
  </div>
</header>
