{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "silo": {
      "type": "string",
      "enum": [
        "strategy",
        "bonuses",
        "rtp",
        "beginner",
        "buying-intent",
        "predictor"
      ]
    },
    "keyword": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "silo",
    "keyword"
  ]
}